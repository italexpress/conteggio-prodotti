// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model IncomingProduct {
  id                  String    @id @default(cuid())
  shop                String
  productId           String    // Shopify Product GID (gid://shopify/Product/xxx)
  variantId           String    // Shopify Variant GID (gid://shopify/ProductVariant/xxx)
  productTitle        String    // Nome prodotto originale Shopify
  variantTitle        String    // Nome variante (es. "Blu / M")
  displayName         String    // Nome combinato visibile (es. "Pantaloni Capri Blu M")
  quantity            Int
  expectedArrivalDate DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([shop])
  @@index([shop, variantId])
}

model OutOfStockProduct {
  id           String   @id @default(cuid())
  shop         String
  variantId    String
  displayName  String
  createdAt    DateTime @default(now())

  @@unique([shop, variantId])
}

model DashboardSettings {
  id                      String  @id @default(cuid())
  shop                    String  @unique

  // Logistics
  shippingRevenue         Float   @default(6.50)    // Quanto paga il cliente per la spedizione
  shippingCost            Float   @default(4.27)    // Costo reale spedizione per l'azienda (IVA inclusa)
  codFeeCharged           Float   @default(4.90)    // Fee COD addebitata al cliente
  codCost                 Float   @default(5.73)    // Costo reale COD per l'azienda (IVA inclusa)
  freeShippingThreshold   Float   @default(69.00)   // Soglia spedizione gratuita
  returnShipmentCost      Float   @default(4.27)    // Costo spedizione ritorno merce (IVA inclusa)

  // Returns
  resoClienteShippingCost Float   @default(4.27)    // RESO_CLIENTE_SPEDISCE: costo spedizione sostitutivo
  resoRimborsoRevenue     Float   @default(9.00)    // RESO_RIMBORSO_RITIRO: quanto paga il cliente
  resoRimborsoCost        Float   @default(5.00)    // RESO_RIMBORSO_RITIRO: costo reale ritiro
  resoExchangeRevenue     Float   @default(11.00)   // RESO_EXCHANGE: quanto paga il cliente
  resoExchangeCost        Float   @default(7.00)    // RESO_EXCHANGE: costo reale cambio

  // Payment Fees
  shopifyFeePercent       Float   @default(1.9)     // Fee Shopify Payments %
  shopifyFeeFixed         Float   @default(0.25)    // Fee Shopify Payments fisso €
  paypalFeePercent        Float   @default(3.4)     // Fee PayPal %
  paypalFeeFixed          Float   @default(0.35)    // Fee PayPal fisso €

  // Tax
  vatPercent              Float   @default(22.0)    // Aliquota IVA %

  // Meta Ads (Fase 3)
  metaAccessToken         String?
  metaAdAccountId         String?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model FixedCost {
  id          String   @id @default(cuid())
  shop        String
  name        String          // es. "Dipendente Mario", "Affitto", "Shopify"
  category    String          // es. "employee", "software", "rent", "accountant", "utilities", "other"
  monthlyCost Float           // Costo mensile
  notes       String?         // Note aggiuntive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shop])
}
