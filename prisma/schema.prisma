// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model IncomingProduct {
  id                  String    @id @default(cuid())
  shop                String
  productId           String    // Shopify Product GID (gid://shopify/Product/xxx)
  variantId           String    // Shopify Variant GID (gid://shopify/ProductVariant/xxx)
  productTitle        String    // Nome prodotto originale Shopify
  variantTitle        String    // Nome variante (es. "Blu / M")
  displayName         String    // Nome combinato visibile (es. "Pantaloni Capri Blu M")
  quantity            Int
  expectedArrivalDate DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([shop])
  @@index([shop, variantId])
}

model OutOfStockProduct {
  id           String   @id @default(cuid())
  shop         String
  variantId    String
  displayName  String
  createdAt    DateTime @default(now())

  @@unique([shop, variantId])
}

model DashboardSettings {
  id                    String  @id @default(cuid())
  shop                  String  @unique

  // Costi spedizione
  shippingCostOutbound  Float   @default(3.50)   // Spedizione andata
  shippingCostReturn    Float   @default(3.50)   // Spedizione reso ritorno
  codManagementFee      Float   @default(1.20)   // Gestione contrassegno

  // Reso rimborso
  returnRefundRevenue   Float   @default(9.00)   // Quanto paga il cliente per reso
  returnRefundCost      Float   @default(5.00)   // Quanto costa all'azienda il reso

  // Reso cambio
  returnExchangeRevenue Float   @default(11.00)  // Quanto paga il cliente per cambio
  returnExchangeCost    Float   @default(7.00)   // Quanto costa all'azienda il cambio

  // Fee pagamento
  shopifyFeePercent     Float   @default(1.9)    // Fee Shopify %
  shopifyFeeFixed       Float   @default(0.25)   // Fee Shopify fisso €
  paypalFeePercent      Float   @default(3.4)    // Fee PayPal %
  paypalFeeFixed        Float   @default(0.35)   // Fee PayPal fisso €

  // IVA
  vatPercent            Float   @default(22.0)

  // Costo spedizione standard per ordine
  defaultShippingCost   Float   @default(5.00)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model FixedCost {
  id          String   @id @default(cuid())
  shop        String
  name        String          // es. "Dipendente Mario", "Affitto", "Shopify"
  category    String          // es. "employee", "software", "rent", "accountant", "utilities", "other"
  monthlyCost Float           // Costo mensile
  notes       String?         // Note aggiuntive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shop])
}
